rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function staffExists() {
      return isAuthenticated()
        && firestore.exists(/databases/(default)/documents/staff/$(request.auth.uid));
    }

    function staffRole() {
      return staffExists()
        ? firestore.get(/databases/(default)/documents/staff/$(request.auth.uid)).data.role
        : '';
    }

    function normalizedRole(role) {
      return role == 'Admin' || role == 'admin' || role == 'Administrator'
        ? 'Admin'
        : role == 'Pastor' || role == 'pastor'
          ? 'Pastor'
          : role == 'Lead Pastor' || role == 'lead pastor'
            ? 'Lead Pastor'
            : role == 'Elder' || role == 'elder'
              ? 'Elder'
              : role == 'Leader' || role == 'leader'
                || role == 'Creative Arts Leader' || role == 'ca leader' || role == 'CA Leader'
                ? 'Leader'
                : role;
    }

    function userRole() {
      return normalizedRole(staffRole());
    }

    function canViewTravelling() {
      return userRole() in ['Admin', 'Pastor', 'Leader', 'Elder'];
    }

    function canManageTravelling() {
      return userRole() in ['Lead Pastor', 'Pastor', 'Admin'];
    }

    function canViewMachanehMovies() {
      return userRole() in ['Lead Pastor', 'Pastor', 'Admin', 'Leader', 'Elder'];
    }

    function canManageMachanehMovies() {
      return userRole() in ['Lead Pastor', 'Pastor', 'Admin'];
    }

    function isTravelDestinationPath(storagePath) {
      return storagePath.matches('travel-destinations/.*');
    }

    function isMachanehMoviePosterPath(storagePath) {
      return storagePath.matches('machaneh-movies/.*');
    }

    function isAllowedTravelImage() {
      return request.resource != null
        && request.resource.contentType.matches('image/(jpeg|png|webp)')
        && request.resource.size <= 5 * 1024 * 1024;
    }

    match /travel-destinations/{destinationId}/{fileName} {
      allow read: if canViewTravelling();
      allow create, update: if canManageTravelling() && isAllowedTravelImage();
      allow delete: if canManageTravelling();
    }

    function isAllowedMoviePoster() {
      return request.resource != null
        && request.resource.contentType.matches('image/(jpeg|png|webp)')
        && request.resource.size <= 5 * 1024 * 1024;
    }

    match /machaneh-movies/{movieId}/{fileName} {
      allow read: if canViewMachanehMovies();
      allow create, update: if canManageMachanehMovies() && isAllowedMoviePoster();
      allow delete: if canManageMachanehMovies();
    }

    // Development: allow authenticated access on other storage paths.
    match /{allPaths=**} {
      allow read, write: if isAuthenticated()
        && !isTravelDestinationPath(allPaths)
        && !isMachanehMoviePosterPath(allPaths);
    }
  }
}
